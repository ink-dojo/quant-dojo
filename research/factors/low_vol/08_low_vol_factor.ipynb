   "source": [
    "# 分组年化收益柱状图\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "\n",
    "ann_rets = {col: group_ret[col].dropna().mean() * 252 for col in group_ret.columns}\n",
